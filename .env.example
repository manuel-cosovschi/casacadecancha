# =====================================================================
# CASACA DE CANCHA - Variables de entorno
# Copiá este archivo a .env.local y completá los valores.
# =====================================================================

# URL pública del sitio (sin barra final). Ej: https://casacadecancha.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Project Settings > API > service_role (SECRETO - solo servidor)
SUPABASE_SERVICE_ROLE_KEY=

# --- Contacto / Marca ---
# Número de WhatsApp en formato internacional sin + ni espacios. Ej: 5492235555555
NEXT_PUBLIC_WHATSAPP_NUMBER=5492235555555
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/casacadecancha

# --- Analítica (opcional) ---
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# --- Pagos ---
# Link de pago de Mercado Pago (MVP)
NEXT_PUBLIC_MERCADOPAGO_LINK=https://link.mercadopago.com.ar/mgbsoftwarefactory

# Futuro: Checkout Pro
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# --- Admin ---
# Email del owner inicial (debe coincidir con el usuario creado en Supabase Auth)
ADMIN_EMAIL=admin@casacadecancha.com

# --- Email transaccional (notificación de comprobantes) ---
# Resend (https://resend.com) - opcional. Si está vacío, no se envían emails.
RESEND_API_KEY=
# Remitente verificado; por defecto usa el de pruebas de Resend.
EMAIL_FROM=Casaca de Cancha <onboarding@resend.dev>

# --- Notificaciones push (Web Push / VAPID) ---
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:cosovschim@gmail.com
# Secreto compartido para que el servidor lea las suscripciones (coincide con push_config.secret)
PUSH_SECRET=

# Secreto para el cron de carrito abandonado (Vercel Cron Authorization)
CRON_SECRET=
